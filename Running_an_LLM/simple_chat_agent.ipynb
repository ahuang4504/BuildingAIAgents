    "# Cell 4: Load Model\n",
    "\n",
    "# Authenticate with Hugging Face\n",
    "hf_token = os.getenv('HF_TOKEN')\n",
    "if hf_token:\n",
    "    print(\"✓ Hugging Face token loaded from .env file\")\n",
    "    login(token=hf_token)\n",
    "else:\n",
    "    # Option 2: Manual entry\n",
    "    print(\"HF_TOKEN not found in .env file\")\n",
    "    hf_token = getpass(\"Enter your Hugging Face token: \")\n",
    "    login(token=hf_token)\n",
    "    print(\"✓ Logged in manually\")\n",
    "\n",
    "print(\"\\nLoading model (this takes 1-2 minutes)...\")\n",
    "\n",
    "# Load tokenizer\n",
    "tokenizer = AutoTokenizer.from_pretrained(MODEL_NAME, token=hf_token)\n",
    "\n",
    "# Load model in half precision\n",
    "model = AutoModelForCausalLM.from_pretrained(\n",
    "    MODEL_NAME,\n",
    "    token=hf_token,\n",
    "    dtype=torch.float16,\n",
    "    device_map=\"auto\",\n",
    "    low_cpu_mem_usage=True\n",
    ")\n",
    "\n",
    "model.eval()\n",
    "print(f\"✓ Model loaded! Using device: {model.device}\")\n",
    "print(\"✓ Memory usage: ~2.5 GB (FP16)\")"
   ]
